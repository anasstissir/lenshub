#!/usr/bin/env bash
# lenshub setup — register all persona skills with Claude Code
set -e

LENSHUB_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$LENSHUB_DIR")"

# 1. Generate SKILL.md files from templates
echo "Generating skill docs..."
(
  cd "$LENSHUB_DIR"
  if command -v bun >/dev/null 2>&1; then
    bun run gen:skill-docs
  else
    echo "Warning: bun not found — skipping SKILL.md generation."
    echo "Install bun: curl -fsSL https://bun.sh/install | bash"
  fi
)

# 2. Only create skill symlinks if we're inside a .claude/skills directory
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$SKILLS_BASENAME" = "skills" ]; then
  linked=()
  for skill_dir in "$LENSHUB_DIR"/skills/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      target="$SKILLS_DIR/$skill_name"
      # Create or update symlink; skip if a real file/directory already exists
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "lenshub/skills/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done

  echo "lenshub ready."
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
else
  echo "lenshub ready."
  echo "  (skipped skill symlinks — not inside .claude/skills/)"
  echo "  To install: clone into ~/.claude/skills/lenshub and re-run ./setup"
fi
