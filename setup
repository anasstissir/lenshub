#!/usr/bin/env bash
# lenshub setup — install all lenshub skills into ~/.claude/skills/
# Works regardless of where the repo is cloned.
set -e

LENSHUB_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"

# 1. Generate SKILL.md files from templates
echo "Generating skill docs..."
(
  cd "$LENSHUB_DIR"
  if command -v bun >/dev/null 2>&1; then
    bun run gen:skill-docs
  else
    echo "Warning: bun not found — skipping SKILL.md generation."
    echo "Install bun: curl -fsSL https://bun.sh/install | bash"
  fi
)

# 2. Symlink the repo itself into ~/.claude/skills/lenshub so the
#    update-check script and lenshub-upgrade can find the .git history.
mkdir -p "$CLAUDE_SKILLS_DIR"
REPO_LINK="$CLAUDE_SKILLS_DIR/lenshub"
if [ -L "$REPO_LINK" ] && [ "$(readlink "$REPO_LINK")" = "$LENSHUB_DIR" ]; then
  : # already correct
elif [ ! -e "$REPO_LINK" ]; then
  ln -s "$LENSHUB_DIR" "$REPO_LINK"
  echo "  linked repo → $REPO_LINK"
else
  echo "Warning: $REPO_LINK exists and is not a symlink to this repo. Skipping."
  echo "  Remove it manually and re-run ./setup if you want to update the target."
fi

# 3. Symlink each individual skill into ~/.claude/skills/<skill-name>
#    Skip skills with platform: cowork (those are distributed via the Cowork UI, not Claude Code)
linked=()
skipped=()
for skill_dir in "$LENSHUB_DIR"/skills/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    platform=$(grep -m1 '^platform:' "$skill_dir/SKILL.md" | awk '{print $2}')
    if [ "$platform" = "cowork" ]; then
      skipped+=("$skill_name")
      continue
    fi
    target="$CLAUDE_SKILLS_DIR/$skill_name"
    if [ -L "$target" ] || [ ! -e "$target" ]; then
      ln -snf "$skill_dir" "$target"
      linked+=("$skill_name")
    else
      echo "Warning: $target exists and is not a symlink. Skipping $skill_name."
    fi
  fi
done

echo "lenshub ready."
if [ ${#linked[@]} -gt 0 ]; then
  echo "  linked skills: ${linked[*]}"
fi
if [ ${#skipped[@]} -gt 0 ]; then
  echo "  cowork-only (not linked): ${skipped[*]}"
fi
echo "  skills dir: $CLAUDE_SKILLS_DIR"
